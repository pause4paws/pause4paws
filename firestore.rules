rules_version = '2';
// ╔══════════════════════════════════════════════════════════════╗
// ║  Pause4Paws — Firestore Security Rules                       ║
// ║  © 2025 Pause4Paws. All rights reserved.                     ║
// ║  Deploy: firebase deploy --only firestore:rules              ║
// ╚══════════════════════════════════════════════════════════════╝
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'pause4paws.app@gmail.com';
    }
    function isPaid() {
      // Checks the user's own record for paid: true
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.paid == true;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── PETS ─────────────────────────────────────────────────────────────────
    // Anyone signed in can read. Only paid members can create/update their own.
    // Admins can do anything.
    match /pets/{petId} {
      allow read: if isSignedIn();
      allow create: if isPaid() &&
        request.resource.data.reporterUid == request.auth.uid;
      allow update: if isAdmin() ||
        (isPaid() && resource.data.reporterUid == request.auth.uid);
      allow delete: if isAdmin();

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isPaid() &&
          request.resource.data.uid == request.auth.uid;
        allow delete: if isAdmin() ||
          (isSignedIn() && resource.data.uid == request.auth.uid);
        allow update: if false; // comments are immutable
      }
    }

    // ── USERS ─────────────────────────────────────────────────────────────────
    // Users can read and write only their own document.
    // Admins can read all.
    // paid field can only be set to true by admin (prevents self-approval).
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.paid == false; // can't self-approve payment
      allow update: if isAdmin() ||
        (isOwner(userId) &&
         !('paid' in request.resource.data.diff(resource.data).affectedKeys())); // can't change paid status
    }

    // ── STATS ─────────────────────────────────────────────────────────────────
    // Anyone can read stats. Only paid members (via markHome) can increment.
    match /stats/{statId} {
      allow read: if true; // public — shown on home screen
      allow write: if isPaid() || isAdmin();
    }

    // ── NOTIFICATIONS ─────────────────────────────────────────────────────────
    // Users can only read/write their own notifications.
    match /notifications/{userId}/items/{notifId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn(); // any signed-in user can write to another's feed
      allow update: if isOwner(userId); // only owner can mark as read
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ── DIRECT MESSAGES ───────────────────────────────────────────────────────
    // Only participants in a thread can read/write.
    match /dms/{threadId} {
      allow read, write: if isSignedIn() &&
        (isAdmin() || request.auth.uid in resource.data.participants);

      match /messages/{msgId} {
        allow read: if isSignedIn() &&
          (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/dms/$(threadId)).data.participants);
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && // for marking read
          request.auth.uid in get(/databases/$(database)/documents/dms/$(threadId)).data.participants;
        allow delete: if isAdmin();
      }
    }

    // ── PUSH TASKS ────────────────────────────────────────────────────────────
    // Written by paid members, read/deleted by Cloud Functions (admin SDK bypasses rules).
    match /pushTasks/{taskId} {
      allow create: if isPaid();
      allow read, delete: if isAdmin(); // Cloud Functions use admin SDK — this is a fallback
    }

    // ── MAP CORRECTIONS ───────────────────────────────────────────────────────
    match /mapCorrections/{corrId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // any signed-in user can report
      allow update, delete: if isAdmin();
    }

    // ── FEATURE REQUESTS ──────────────────────────────────────────────────────
    match /featureRequests/{reqId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // ── DEFAULT: deny everything else ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
